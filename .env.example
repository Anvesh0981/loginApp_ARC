# Copy this to Railway / Render environment variables
# DO NOT commit the actual values to git

# PostgreSQL connection string (provided automatically by Railway PostgreSQL addon)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Strong random secret for Flask sessions (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=replace_with_random_hex_64_chars

# Admin panel password — change this immediately
ADMIN_PASSWORD=change_me_now

# The static target URL all logins point to
TARGET_URL=https://abc-app.example.com/login
